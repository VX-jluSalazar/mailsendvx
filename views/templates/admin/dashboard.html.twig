{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
  <section class="mailsendvx-shell">
    <div class="mailsendvx-hero">
      <div class="mailsendvx-hero__copy">
        <span class="mailsendvx-eyebrow">{{ 'Vista de monitoreo'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
        <h1 class="mailsendvx-page-title">{{ 'Dashboard de Mail Send VX'|trans({}, 'Modules.Mailsendvx.Admin') }}</h1>
        <p class="mailsendvx-page-subtitle">
          {{ 'Revisa el estado de las plantillas y la carga de la cola antes de analizar los logs individuales de envío.'|trans({}, 'Modules.Mailsendvx.Admin') }}
        </p>
      </div>
      <div class="mailsendvx-status-cluster">
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Templates'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
          <strong class="mailsendvx-metric__value">{{ templates_count }}</strong>
        </div>
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Programados'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
          <strong class="mailsendvx-metric__value">{{ scheduled_count }}</strong>
        </div>
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Pendientes'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
          <strong class="mailsendvx-metric__value">{{ pending_count }}</strong>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-xl-4">
        <div class="card mailsendvx-card mailsendvx-card--aside">
          <h3 class="card-header">
            <i class="material-icons">pulse_alert</i>
            {{ 'Estado de la cola'|trans({}, 'Modules.Mailsendvx.Admin') }}
          </h3>
          <div class="card-body">
            <div class="mailsendvx-signal {{ pending_count > 0 ? 'mailsendvx-signal--warning' : 'mailsendvx-signal--healthy' }}">
              <strong>
                {% if pending_count > 0 %}
                  {{ 'Hay envíos pendientes que requieren revisión.'|trans({}, 'Modules.Mailsendvx.Admin') }}
                {% else %}
                  {{ 'No hay envíos pendientes en este momento.'|trans({}, 'Modules.Mailsendvx.Admin') }}
                {% endif %}
              </strong>
              <p>
                {% if scheduled_count > 0 %}
                  {{ 'Hay correos en cola programados para procesarse.'|trans({}, 'Modules.Mailsendvx.Admin') }}
                {% else %}
                  {{ 'La cola está estable y no hay correos programados en espera.'|trans({}, 'Modules.Mailsendvx.Admin') }}
                {% endif %}
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="col-xl-8">
        {{ include('@PrestaShop/Admin/Common/Grid/grid_panel.html.twig', {'grid': eventsGrid }) }}

        <div class="mt-3">
          {{ include('@PrestaShop/Admin/Common/Grid/grid_panel.html.twig', {'grid': logsGrid }) }}
        </div>
      </div>
    </div>
  </section>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    {{ include('@Modules/mailsendvx/views/js/mailsendvx-grid.bundle.js')|raw }}
  </script>
  <script src="{{ asset('themes/default/js/bundle/pagination.js') }}"></script>
{% endblock %}
