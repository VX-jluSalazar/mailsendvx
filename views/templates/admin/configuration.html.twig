{% form_theme configurationForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}
{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
  {{ form_start(configurationForm, {attr: {class: 'mailsendvx-form'}}) }}
  <section class="mailsendvx-shell">
    <div class="mailsendvx-hero">
      <div class="mailsendvx-hero__copy">
        <span class="mailsendvx-eyebrow">{{ 'Back office control'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
        <h1 class="mailsendvx-page-title">{{ 'Configuration'|trans({}, 'Admin.Global') }}</h1>
        <p class="mailsendvx-page-subtitle">
          {{ 'Tune how instant emails are captured and keep the module behavior predictable for the current shop context.'|trans({}, 'Modules.Mailsendvx.Admin') }}
        </p>
      </div>
      <div class="mailsendvx-status-cluster">
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Shop'|trans({}, 'Admin.Global') }}</span>
          <strong class="mailsendvx-metric__value">{{ shopName }}</strong>
        </div>
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Capture'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
          <strong class="mailsendvx-metric__value">{{ configurationData.enabled ? 'Enabled'|trans({}, 'Admin.Global') : 'Disabled'|trans({}, 'Admin.Global') }}</strong>
        </div>
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Debug'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
          <strong class="mailsendvx-metric__value">{{ configurationData.debug ? 'On'|trans({}, 'Modules.Mailsendvx.Admin') : 'Off'|trans({}, 'Modules.Mailsendvx.Admin') }}</strong>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-xl-8">
        <div class="card mailsendvx-card">
          <h3 class="card-header">
            <i class="material-icons">settings</i>
            {{ 'Mail Send VX Configuration'|trans({}, 'Modules.Mailsendvx.Admin') }}
          </h3>
          <div class="card-body">
            <div class="form-wrapper">
              {{ form_widget(configurationForm) }}
            </div>
          </div>
          <div class="card-footer text-right">
            <button type="submit" class="btn btn-primary">
              {{ 'Save changes'|trans({}, 'Modules.Mailsendvx.Admin') }}
            </button>
          </div>
        </div>
      </div>

      <div class="col-xl-4">
        <div class="card mailsendvx-card mailsendvx-card--aside">
          <h3 class="card-header">
            <i class="material-icons">tips_and_updates</i>
            {{ 'Operational notes'|trans({}, 'Modules.Mailsendvx.Admin') }}
          </h3>
          <div class="card-body">
            <ul class="mailsendvx-note-list">
              <li>{{ 'Provider is locked to the current delivery adapter while phase 3 keeps repository and domain work in progress.'|trans({}, 'Modules.Mailsendvx.Admin') }}</li>
              <li>{{ 'Enable debug mode only when reviewing logs or reproducing delivery issues in Back Office.'|trans({}, 'Modules.Mailsendvx.Admin') }}</li>
              <li>{{ 'Changes apply to instant event capture and are safe to update without leaving this screen.'|trans({}, 'Modules.Mailsendvx.Admin') }}</li>
              <li>{{ 'Abandoned cart detection runs from the module cron endpoint and uses cycle dedupe to avoid registering the same cart repeatedly.'|trans({}, 'Modules.Mailsendvx.Admin') }}</li>
            </ul>
            <p class="mt-3 mb-0">
              <strong>{{ 'Cron URL'|trans({}, 'Modules.Mailsendvx.Admin') }}:</strong><br>
              <code>{{ abandonedCartCronUrl }}</code>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
  {{ form_end(configurationForm) }}
{% endblock %}
