{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
  <section class="mailsendvx-shell">
    <div class="mailsendvx-hero">
      <div class="mailsendvx-hero__copy">
        <span class="mailsendvx-eyebrow">{{ 'Estudio de plantillas'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
        <h1 class="mailsendvx-page-title">{{ 'Plantillas instantáneas y reutilizables'|trans({}, 'Modules.Mailsendvx.Admin') }}</h1>
        <p class="mailsendvx-page-subtitle">
          {{ 'Consulta el catálogo de plantillas, filtra por contexto o estado y abre la edición en una pantalla dedicada.'|trans({}, 'Modules.Mailsendvx.Admin') }}
        </p>
      </div>
      <div class="mailsendvx-status-cluster">
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Shop'|trans({}, 'Admin.Global') }}</span>
          <strong class="mailsendvx-metric__value">{{ shopName }}</strong>
        </div>
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Templates'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
          <strong class="mailsendvx-metric__value">{{ templatesCount }}</strong>
        </div>
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Active'|trans({}, 'Admin.Global') }}</span>
          <strong class="mailsendvx-metric__value">{{ activeTemplatesCount }}</strong>
        </div>
      </div>
    </div>

    <div class="card mailsendvx-card">
      <div class="card-header mailsendvx-card-header-actions">
        <div class="mailsendvx-card-header-copy">
          <i class="material-icons">list</i>
          <span>{{ 'Templates'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
        </div>
        <a class="btn btn-primary" href="{{ path('mailsendvx_template_create') }}">
          {{ 'Crear plantilla'|trans({}, 'Modules.Mailsendvx.Admin') }}
        </a>
      </div>
      <div class="card-body">
        {{ include('@PrestaShop/Admin/Common/Grid/grid_panel.html.twig', {'grid': templatesGrid }) }}
      </div>
    </div>
  </section>

  <div class="mailsendvx-modal" id="mailsendvx-preview-modal" hidden>
    <div class="mailsendvx-modal__backdrop" data-preview-close></div>
    <div class="mailsendvx-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="mailsendvx-preview-modal-title">
      <div class="mailsendvx-modal__header">
        <div>
          <span class="mailsendvx-eyebrow">{{ 'Previsualización'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
          <h3 id="mailsendvx-preview-modal-title" class="mailsendvx-modal__title"></h3>
        </div>
        <button type="button" class="close" aria-label="{{ 'Cerrar'|trans({}, 'Admin.Actions') }}" data-preview-close>
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="mailsendvx-modal__body">
        <div class="alert alert-danger mailsendvx-modal-feedback" id="mailsendvx-preview-feedback" role="alert"></div>
        <div class="mailsendvx-inline-note" id="mailsendvx-preview-note">
        </div>
        <div class="mailsendvx-preview-subject">
          <span>{{ 'Subject'|trans({}, 'Admin.Global') }}</span>
          <strong id="mailsendvx-preview-subject"></strong>
        </div>
        <div class="mailsendvx-preview-frame" id="mailsendvx-preview-frame"></div>
        <pre class="mailsendvx-text-preview" id="mailsendvx-preview-text"></pre>
      </div>
      <div class="mailsendvx-modal__footer">
        <form method="post" action="" class="mailsendvx-test-form" id="mailsendvx-preview-test-form">
          <input type="hidden" name="_token" value="">
          <input type="hidden" name="edit" value="0">
          <input type="hidden" name="preview" value="0">
          <input type="email" name="test_email" class="form-control" id="mailsendvx-preview-test-email" value="{{ defaultTestEmail }}" placeholder="{{ 'Correo de prueba'|trans({}, 'Modules.Mailsendvx.Admin') }}" required>
          <button type="submit" class="btn btn-primary btn-sm">{{ 'Enviar prueba'|trans({}, 'Modules.Mailsendvx.Admin') }}</button>
        </form>
      </div>
    </div>
  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    {{ include('@Modules/mailsendvx/views/js/mailsendvx-grid.bundle.js')|raw }}
  </script>
  <script src="{{ asset('themes/default/js/bundle/pagination.js') }}"></script>
{% endblock %}
