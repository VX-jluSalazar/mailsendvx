{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
  <section class="mailsendvx-shell">
    <div class="mailsendvx-hero">
      <div class="mailsendvx-hero__copy">
        <span class="mailsendvx-eyebrow">{{ 'Control de layout'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
        <h1 class="mailsendvx-page-title">{{ 'Wrappers'|trans({}, 'Modules.Mailsendvx.Admin') }}</h1>
        <p class="mailsendvx-page-subtitle">
          {{ 'Gestiona wrappers persistidos por tienda e idioma, manteniendo como fallback los archivos base del módulo.'|trans({}, 'Modules.Mailsendvx.Admin') }}
        </p>
      </div>
      <div class="mailsendvx-status-cluster">
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Shop'|trans({}, 'Admin.Global') }}</span>
          <strong class="mailsendvx-metric__value">{{ shopName }}</strong>
        </div>
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Wrappers disponibles'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
          <strong class="mailsendvx-metric__value">{{ wrappers|length }}</strong>
        </div>
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Language'|trans({}, 'Admin.Global') }}</span>
          <strong class="mailsendvx-metric__value">{{ selectedLanguageCode ?: '-' }}</strong>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-xl-7">
        <form method="post" class="mailsendvx-form">
          <input type="hidden" name="_token" value="{{ csrf_token('mailsendvx-wrapper-save') }}">
          <div class="card mailsendvx-card">
            <h3 class="card-header">
              <i class="material-icons">view_quilt</i>
              {{ 'Editor de wrappers'|trans({}, 'Modules.Mailsendvx.Admin') }}
            </h3>
            <div class="card-body">
              <div class="mailsendvx-inline-note">
                {{ 'Al guardar, el wrapper queda persistido para la tienda actual y el idioma seleccionado. Si no existe override persistido, el módulo seguirá usando el archivo base.'|trans({}, 'Modules.Mailsendvx.Admin') }}
              </div>

              <div class="row">
                <div class="col-md-6">
                  <div class="form-group">
                    <label class="form-control-label" for="wrapper_name">{{ 'Clave del wrapper'|trans({}, 'Modules.Mailsendvx.Admin') }}</label>
                    <input type="text" id="wrapper_name" name="wrapper_name" class="form-control" value="{{ selectedWrapper }}" required>
                    <small class="form-text text-muted">{{ 'Ejemplo: mailsendvx_default'|trans({}, 'Modules.Mailsendvx.Admin') }}</small>
                  </div>
                </div>
                <div class="col-md-6">
                  <div class="form-group">
                    <label class="form-control-label" for="id_lang">{{ 'Idioma'|trans({}, 'Modules.Mailsendvx.Admin') }}</label>
                    <select id="id_lang" name="id_lang" class="form-control">
                      {% for language in languages %}
                        <option value="{{ language.id_lang }}" {% if language.id_lang == selectedLangId %}selected{% endif %}>{{ language.name }}</option>
                      {% endfor %}
                    </select>
                    <small class="form-text text-muted">{{ 'El contenido se guarda y resuelve por idioma dentro de esta tienda.'|trans({}, 'Modules.Mailsendvx.Admin') }}</small>
                  </div>
                </div>
              </div>

              <div class="form-group">
                <label class="form-control-label" for="wrapper_html">{{ 'HTML del wrapper'|trans({}, 'Modules.Mailsendvx.Admin') }}</label>
                <textarea id="wrapper_html" name="wrapper_html" class="form-control" rows="12" required>{{ wrapperHtml }}</textarea>
                <small class="form-text text-muted">{{ 'El wrapper HTML debe incluir {{ mailsendvx_html_content|raw }}.'|trans({}, 'Modules.Mailsendvx.Admin') }}</small>
              </div>

              <div class="form-group">
                <label class="form-control-label" for="wrapper_text">{{ 'Texto del wrapper'|trans({}, 'Modules.Mailsendvx.Admin') }}</label>
                <textarea id="wrapper_text" name="wrapper_text" class="form-control" rows="8">{{ wrapperText }}</textarea>
                <small class="form-text text-muted">{{ 'Déjalo vacío si quieres que el módulo genere automáticamente un wrapper base de texto desde el HTML y use {{ mailsendvx_text_content }}.'|trans({}, 'Modules.Mailsendvx.Admin') }}</small>
              </div>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center">
              <a class="btn btn-outline-secondary" href="{{ path('mailsendvx_wrappers', {wrapper: selectedWrapper, id_lang: selectedLangId}) }}">
                {{ 'Restablecer formulario'|trans({}, 'Modules.Mailsendvx.Admin') }}
              </a>
              <button type="submit" class="btn btn-primary">
                {{ 'Guardar wrapper'|trans({}, 'Modules.Mailsendvx.Admin') }}
              </button>
            </div>
          </div>
        </form>
      </div>

      <div class="col-xl-5">
        <div class="card mailsendvx-card mailsendvx-card--aside">
          <h3 class="card-header">
            <i class="material-icons">layers</i>
            {{ 'Wrappers disponibles'|trans({}, 'Modules.Mailsendvx.Admin') }}
          </h3>
          <div class="card-body">
            <ul class="mailsendvx-note-list">
              {% for wrapperName, wrapperLabel in wrappers %}
                <li>
                  <a href="{{ path('mailsendvx_wrappers', {wrapper: wrapperName, id_lang: selectedLangId}) }}"><code>{{ wrapperName }}</code></a>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>

        <div class="card mailsendvx-card mailsendvx-card--aside mt-3">
          <h3 class="card-header">
            <i class="material-icons">tips_and_updates</i>
            {{ 'Reglas del wrapper'|trans({}, 'Modules.Mailsendvx.Admin') }}
          </h3>
          <div class="card-body">
            <ul class="mailsendvx-note-list">
              <li>{{ 'El wrapper HTML debe contener {{ mailsendvx_html_content|raw }} exactamente una vez.'|trans({}, 'Modules.Mailsendvx.Admin') }}</li>
              <li>{{ 'El wrapper de texto debe contener {{ mailsendvx_text_content }}.'|trans({}, 'Modules.Mailsendvx.Admin') }}</li>
              <li>{{ 'Usa solo Twig en wrappers: {{ shop.name }}, {{ shop.url }}, {{ shop.logo_url }}, {{ shop.contact_email }}, {{ shop.unsubscribe_url }}, {{ customer.email }} y el resto del payload.'|trans({}, 'Modules.Mailsendvx.Admin') }}</li>
              <li>{{ 'Los archivos del módulo quedan como fallback; las ediciones desde Back Office se persisten en base de datos por tienda e idioma.'|trans({}, 'Modules.Mailsendvx.Admin') }}</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <div class="card mailsendvx-card mt-3">
      <h3 class="card-header">
        <i class="material-icons">list</i>
        {{ 'Wrappers'|trans({}, 'Modules.Mailsendvx.Admin') }}
      </h3>
      <div class="card-body">
        {% if wrapperRows %}
          <div class="table-responsive">
            <table class="table mailsendvx-table">
              <thead>
                <tr>
                  <th>{{ 'Name'|trans({}, 'Admin.Global') }}</th>
                  <th>{{ 'Language'|trans({}, 'Admin.Global') }}</th>
                  <th>{{ 'Shop'|trans({}, 'Admin.Global') }}</th>
                  <th>{{ 'Origen'|trans({}, 'Modules.Mailsendvx.Admin') }}</th>
                  <th>{{ 'Actualizado'|trans({}, 'Modules.Mailsendvx.Admin') }}</th>
                  <th>{{ 'Actions'|trans({}, 'Admin.Actions') }}</th>
                </tr>
              </thead>
              <tbody>
                {% for wrapper in wrapperRows %}
                  <tr>
                    <td>
                      <strong>{{ wrapper.name }}</strong>
                      {% if wrapper.id_mailsendvx_wrapper %}
                        <div class="mailsendvx-table-meta">#{{ wrapper.id_mailsendvx_wrapper }}</div>
                      {% endif %}
                    </td>
                    <td>{{ wrapper.language_label }}</td>
                    <td>{{ wrapper.shop_label }}</td>
                    <td>
                      <span class="mailsendvx-badge {{ wrapper.source_badge_class }}">{{ wrapper.source_label }}</span>
                    </td>
                    <td>{{ wrapper.date_upd ?: '-' }}</td>
                    <td class="mailsendvx-template-actions">
                      <div class="mailsendvx-action-row">
                        <a class="btn btn-outline-secondary btn-sm" href="{{ path('mailsendvx_wrappers', {wrapper: wrapper.name, id_lang: wrapper.id_lang}) }}">{{ 'Editar'|trans({}, 'Modules.Mailsendvx.Admin') }}</a>
                        {% if wrapper.id_mailsendvx_wrapper %}
                          <form method="post" action="{{ path('mailsendvx_wrapper_delete', {idWrapper: wrapper.id_mailsendvx_wrapper}) }}" class="mailsendvx-inline-form" onsubmit="return confirm('{{ '¿Eliminar este wrapper persistido de la tienda actual?'|trans({}, 'Modules.Mailsendvx.Admin')|e('js') }}');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-wrapper-' ~ wrapper.id_mailsendvx_wrapper) }}">
                            <button type="submit" class="btn btn-outline-danger btn-sm">{{ 'Eliminar'|trans({}, 'Modules.Mailsendvx.Admin') }}</button>
                          </form>
                        {% endif %}
                      </div>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% else %}
          <div class="mailsendvx-empty-state">
            <h3>{{ 'Aún no hay wrappers.'|trans({}, 'Modules.Mailsendvx.Admin') }}</h3>
            <p>{{ 'Puedes empezar editando mailsendvx_default o crear una nueva clave reutilizable para esta tienda.'|trans({}, 'Modules.Mailsendvx.Admin') }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </section>
{% endblock %}
