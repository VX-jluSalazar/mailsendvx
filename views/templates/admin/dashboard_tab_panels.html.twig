{% form_theme configurationForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}

{% if activeTab == 'events' %}
  <section class="mailsendvx-tab-panel is-active" data-tab-panel="events">
    <div
      class="mailsendvx-grid-shell"
      data-mailsendvx-ajax-grid="1"
      data-grid-id="mailsendvx_events"
      data-grid-panel-endpoint="{{ path('mailsendvx_dashboard_grid', {gridId: 'mailsendvx_events', tab: 'events'}) }}"
      data-grid-tab="events"
      data-grid-ajax-actions="0"
    >
      {{ include('@Modules/mailsendvx/views/templates/admin/partials/grid_panel.html.twig', {'grid': eventsGrid }) }}
    </div>
  </section>
{% elseif activeTab == 'queue' %}
  <section class="mailsendvx-tab-panel is-active" data-tab-panel="queue">
    <div class="card mailsendvx-card mailsendvx-card--aside mb-3">
      <div class="card-body mailsendvx-inline-action">
        <div>
          <strong>{{ 'Los steps programados necesitan que corra el worker de queue.'|trans({}, 'Modules.Mailsendvx.Admin') }}</strong>
          <p>{{ 'El primer mail puede salir al instante, pero los siguientes sólo se enviarán después de su fecha programada cuando ejecutes el cron o lances el worker manualmente desde aquí.'|trans({}, 'Modules.Mailsendvx.Admin') }}</p>
        </div>
        <div class="mailsendvx-inline-actions-stack">
        <form
          method="post"
          action="{{ path('mailsendvx_queue_run') }}"
          class="mailsendvx-inline-runner"
          data-mailsendvx-ajax-form="1"
          data-refresh-grid-id="mailsendvx_queue"
        >
          <input type="hidden" name="_token" value="{{ csrf_token('mailsendvx-flow-save') }}">
          <input type="hidden" name="queue_limit" value="50">
          <button type="submit" class="btn btn-primary">{{ 'Procesar queue ahora'|trans({}, 'Modules.Mailsendvx.Admin') }}</button>
        </form>
        <form
          method="post"
          action="{{ path('mailsendvx_queue_clear') }}"
          class="mailsendvx-inline-runner"
          data-mailsendvx-ajax-form="1"
          data-refresh-grid-id="mailsendvx_queue"
          data-confirm-message="{{ '¿Limpiar el histórico terminal de la queue? Se conservarán jobs pending, scheduled y processing.'|trans({}, 'Modules.Mailsendvx.Admin') }}"
        >
          <input type="hidden" name="_token" value="{{ csrf_token('mailsendvx-queue-clear') }}">
          <button type="submit" class="btn btn-outline-danger">{{ 'Limpiar tabla'|trans({}, 'Modules.Mailsendvx.Admin') }}</button>
        </form>
        </div>
      </div>
    </div>
    <div
      class="mailsendvx-grid-shell"
      data-mailsendvx-ajax-grid="1"
      data-grid-id="mailsendvx_queue"
      data-grid-panel-endpoint="{{ path('mailsendvx_dashboard_grid', {gridId: 'mailsendvx_queue', tab: 'queue'}) }}"
      data-grid-tab="queue"
      data-grid-ajax-actions="1"
    >
      {{ include('@Modules/mailsendvx/views/templates/admin/partials/grid_panel.html.twig', {'grid': queueGrid }) }}
    </div>
  </section>
{% elseif activeTab == 'logs' %}
  <section class="mailsendvx-tab-panel is-active" data-tab-panel="logs">
    <div
      class="mailsendvx-grid-shell"
      data-mailsendvx-ajax-grid="1"
      data-grid-id="mailsendvx_logs"
      data-grid-panel-endpoint="{{ path('mailsendvx_dashboard_grid', {gridId: 'mailsendvx_logs', tab: 'logs'}) }}"
      data-grid-tab="logs"
      data-grid-ajax-actions="0"
    >
      {{ include('@Modules/mailsendvx/views/templates/admin/partials/grid_panel.html.twig', {'grid': logsGrid }) }}
    </div>
  </section>
{% elseif activeTab == 'configuration' %}
  <section class="mailsendvx-tab-panel is-active" data-tab-panel="configuration">
    {{ form_start(configurationForm, {attr: {class: 'mailsendvx-form'}}) }}
      <div class="row">
        <div class="col-xl-12">
          <div class="card mailsendvx-card">
            <h3 class="card-header">
              <i class="material-icons">settings</i>
              {{ 'Configuración general'|trans({}, 'Modules.Mailsendvx.Admin') }}
            </h3>
            <div class="card-body">
              <div class="form-wrapper">
                {{ form_errors(configurationForm) }}
                {{ form_row(configurationForm.mailsendvx_configuration.enabled) }}
                {{ form_row(configurationForm.mailsendvx_configuration.provider) }}
                {{ form_row(configurationForm.mailsendvx_configuration.debug) }}
              </div>
            </div>
          </div>

          <div class="card mailsendvx-card mt-3">
            <h3 class="card-header">
              <i class="material-icons">shopping_cart</i>
              {{ 'Configuración de carrito abandonado'|trans({}, 'Modules.Mailsendvx.Admin') }}
            </h3>
            <div class="card-body">
              <div class="mailsendvx-inline-note">
                {{ 'Estos ajustes controlan cuándo un carrito se considera abandonado y con qué intensidad el cron escanea candidatos.'|trans({}, 'Modules.Mailsendvx.Admin') }}
              </div>
              <div class="mailsendvx-settings-grid">
                <div class="mailsendvx-setting mailsendvx-setting--switch">
                  <div class="mailsendvx-setting__label">
                    <span class="mailsendvx-setting__label-row">
                      {{ form_label(configurationForm.mailsendvx_configuration.abandoned_cart_enabled) }}
                      <span class="mailsendvx-help-icon" title="{{ 'Activa o desactiva la detección completa de carrito abandonado.'|trans({}, 'Modules.Mailsendvx.Admin') }}" aria-label="{{ 'Ayuda'|trans({}, 'Admin.Global') }}">
                        <i class="material-icons">info</i>
                      </span>
                    </span>
                  </div>
                  <div class="mailsendvx-setting__field">
                    {{ form_widget(configurationForm.mailsendvx_configuration.abandoned_cart_enabled) }}
                    {{ form_errors(configurationForm.mailsendvx_configuration.abandoned_cart_enabled) }}
                  </div>
                </div>

                <div class="mailsendvx-setting">
                  <div class="mailsendvx-setting__label">
                    <span class="mailsendvx-setting__label-row">
                      {{ form_label(configurationForm.mailsendvx_configuration.abandoned_cart_delay_value) }}
                      <span class="mailsendvx-help-icon" title="{{ 'Valor numérico de la ventana de inactividad antes de considerar un carrito como abandonado.'|trans({}, 'Modules.Mailsendvx.Admin') }}" aria-label="{{ 'Ayuda'|trans({}, 'Admin.Global') }}">
                        <i class="material-icons">info</i>
                      </span>
                    </span>
                  </div>
                  <div class="mailsendvx-setting__field">
                    {{ form_widget(configurationForm.mailsendvx_configuration.abandoned_cart_delay_value) }}
                    {{ form_errors(configurationForm.mailsendvx_configuration.abandoned_cart_delay_value) }}
                  </div>
                </div>

                <div class="mailsendvx-setting">
                  <div class="mailsendvx-setting__label">
                    <span class="mailsendvx-setting__label-row">
                      {{ form_label(configurationForm.mailsendvx_configuration.abandoned_cart_delay_unit) }}
                      <span class="mailsendvx-help-icon" title="{{ 'Unidad de tiempo usada por el retraso: minutos, horas, días o semanas.'|trans({}, 'Modules.Mailsendvx.Admin') }}" aria-label="{{ 'Ayuda'|trans({}, 'Admin.Global') }}">
                        <i class="material-icons">info</i>
                      </span>
                    </span>
                  </div>
                  <div class="mailsendvx-setting__field">
                    {{ form_widget(configurationForm.mailsendvx_configuration.abandoned_cart_delay_unit) }}
                    {{ form_errors(configurationForm.mailsendvx_configuration.abandoned_cart_delay_unit) }}
                  </div>
                </div>

                <div class="mailsendvx-setting">
                  <div class="mailsendvx-setting__label">
                    <span class="mailsendvx-setting__label-row">
                      {{ form_label(configurationForm.mailsendvx_configuration.abandoned_cart_cron_batch_size) }}
                      <span class="mailsendvx-help-icon" title="{{ 'Cantidad máxima de carritos candidatos procesados en cada ejecución del cron.'|trans({}, 'Modules.Mailsendvx.Admin') }}" aria-label="{{ 'Ayuda'|trans({}, 'Admin.Global') }}">
                        <i class="material-icons">info</i>
                      </span>
                    </span>
                  </div>
                  <div class="mailsendvx-setting__field">
                    {{ form_widget(configurationForm.mailsendvx_configuration.abandoned_cart_cron_batch_size) }}
                    {{ form_errors(configurationForm.mailsendvx_configuration.abandoned_cart_cron_batch_size) }}
                  </div>
                </div>
              </div>
            </div>
            <div class="card-footer text-right">
              <button type="submit" class="btn btn-primary">
                {{ 'Guardar cambios'|trans({}, 'Modules.Mailsendvx.Admin') }}
              </button>
            </div>
          </div>
        </div>
      </div>
      {{ form_rest(configurationForm) }}
    {{ form_end(configurationForm, {'render_rest': false}) }}
  </section>
{% endif %}
