{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
  <section class="mailsendvx-shell">
    <div class="mailsendvx-hero">
      <div class="mailsendvx-hero__copy">
        <span class="mailsendvx-eyebrow">{{ 'Vista de monitoreo'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
        <h1 class="mailsendvx-page-title">{{ 'Dashboard de Mail Send VX'|trans({}, 'Modules.Mailsendvx.Admin') }}</h1>
        <p class="mailsendvx-page-subtitle">
          {{ 'Revisa el estado de las plantillas y la carga de la cola antes de analizar los logs individuales de envío.'|trans({}, 'Modules.Mailsendvx.Admin') }}
        </p>
      </div>
      <div class="mailsendvx-status-cluster">
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Templates'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
          <strong class="mailsendvx-metric__value">{{ templates_count }}</strong>
        </div>
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Programados'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
          <strong class="mailsendvx-metric__value">{{ scheduled_count }}</strong>
        </div>
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Pendientes'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
          <strong class="mailsendvx-metric__value">{{ pending_count }}</strong>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-xl-4">
        <div class="card mailsendvx-card mailsendvx-card--aside">
          <h3 class="card-header">
            <i class="material-icons">pulse_alert</i>
            {{ 'Estado de la cola'|trans({}, 'Modules.Mailsendvx.Admin') }}
          </h3>
          <div class="card-body">
            <div class="mailsendvx-signal {{ pending_count > 0 ? 'mailsendvx-signal--warning' : 'mailsendvx-signal--healthy' }}">
              <strong>
                {% if pending_count > 0 %}
                  {{ 'Hay envíos pendientes que requieren revisión.'|trans({}, 'Modules.Mailsendvx.Admin') }}
                {% else %}
                  {{ 'No hay envíos pendientes en este momento.'|trans({}, 'Modules.Mailsendvx.Admin') }}
                {% endif %}
              </strong>
              <p>
                {% if scheduled_count > 0 %}
                  {{ 'Hay correos en cola programados para procesarse.'|trans({}, 'Modules.Mailsendvx.Admin') }}
                {% else %}
                  {{ 'La cola está estable y no hay correos programados en espera.'|trans({}, 'Modules.Mailsendvx.Admin') }}
                {% endif %}
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="col-xl-8">
        <div class="card mailsendvx-card mb-3">
          <h3 class="card-header">
            <i class="material-icons">bolt</i>
            {{ 'Eventos capturados'|trans({}, 'Modules.Mailsendvx.Admin') }}
          </h3>
          <div class="card-body">
            {% if recent_events %}
              <div class="table-responsive">
                <table class="table mailsendvx-table">
                  <thead>
                    <tr>
                      <th>{{ 'Date'|trans({}, 'Admin.Global') }}</th>
                      <th>{{ 'Event'|trans({}, 'Modules.Mailsendvx.Admin') }}</th>
                      <th>{{ 'Status'|trans({}, 'Admin.Global') }}</th>
                      <th>{{ 'Tipo de objeto'|trans({}, 'Modules.Mailsendvx.Admin') }}</th>
                      <th>{{ 'ID del objeto'|trans({}, 'Modules.Mailsendvx.Admin') }}</th>
                      <th>{{ 'Shop'|trans({}, 'Admin.Global') }}</th>
                      <th>{{ 'Payload'|trans({}, 'Modules.Mailsendvx.Admin') }}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for event in recent_events %}
                      <tr>
                        <td>{{ event.date_add }}</td>
                        <td><code>{{ event.event_name }}</code></td>
                        <td>
                          <span class="mailsendvx-badge {{ event.status in ['captured', 'sent', 'success'] ? 'mailsendvx-badge--success' : (event.status in ['pending', 'scheduled'] ? 'mailsendvx-badge--warning' : 'mailsendvx-badge--danger') }}">
                            {{ event.status }}
                          </span>
                        </td>
                        <td>{{ event.object_type ?: '-' }}</td>
                        <td>{{ event.object_id ?: '-' }}</td>
                        <td>{{ event.id_shop ?: '-' }}</td>
                        <td>
                          {% if event.payload %}
                            <details>
                              <summary>{{ 'Ver payload'|trans({}, 'Modules.Mailsendvx.Admin') }}</summary>
                              <pre class="mailsendvx-payload">{{ event.payload }}</pre>
                            </details>
                          {% else %}
                            -
                          {% endif %}
                        </td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            {% else %}
              <div class="mailsendvx-empty-state">
                <h3>{{ 'Aún no hay eventos capturados.'|trans({}, 'Modules.Mailsendvx.Admin') }}</h3>
                <p>{{ 'Los payloads capturados por hooks aparecerán aquí cuando el primer evento instantáneo llegue al módulo.'|trans({}, 'Modules.Mailsendvx.Admin') }}</p>
              </div>
            {% endif %}
          </div>
        </div>

        <div class="card mailsendvx-card">
          <h3 class="card-header">
            <i class="material-icons">history</i>
            {{ 'Logs recientes'|trans({}, 'Modules.Mailsendvx.Admin') }}
          </h3>
          <div class="card-body">
            {% if recent_logs %}
              <div class="table-responsive">
                <table class="table mailsendvx-table">
                  <thead>
                    <tr>
                      <th>{{ 'Date'|trans({}, 'Admin.Global') }}</th>
                      <th>{{ 'Event'|trans({}, 'Modules.Mailsendvx.Admin') }}</th>
                      <th>{{ 'Status'|trans({}, 'Admin.Global') }}</th>
                      <th>{{ 'Destinatario'|trans({}, 'Modules.Mailsendvx.Admin') }}</th>
                      <th>{{ 'Message'|trans({}, 'Admin.Global') }}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for log in recent_logs %}
                      <tr>
                        <td>{{ log.date_add }}</td>
                        <td><code>{{ log.event_name }}</code></td>
                        <td>
                          <span class="mailsendvx-badge {{ log.status in ['sent', 'success'] ? 'mailsendvx-badge--success' : (log.status in ['pending', 'scheduled'] ? 'mailsendvx-badge--warning' : 'mailsendvx-badge--danger') }}">
                            {{ log.status }}
                          </span>
                        </td>
                        <td>{{ log.recipient ?: '-' }}</td>
                        <td>{{ log.message ?: '-' }}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            {% else %}
              <div class="mailsendvx-empty-state">
                <h3>{{ 'Aún no hay logs.'|trans({}, 'Modules.Mailsendvx.Admin') }}</h3>
                <p>{{ 'El historial reciente de envíos aparecerá aquí después del primer evento capturado o del primer envío de prueba.'|trans({}, 'Modules.Mailsendvx.Admin') }}</p>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </section>
{% endblock %}
