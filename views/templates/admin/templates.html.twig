{% form_theme templateForm '@PrestaShop/Admin/TwigTemplateForm/prestashop_ui_kit.html.twig' %}
{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
  <section class="mailsendvx-shell">
    <div class="mailsendvx-hero">
      <div class="mailsendvx-hero__copy">
        <span class="mailsendvx-eyebrow">{{ 'Estudio de plantillas'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
        <h1 class="mailsendvx-page-title">{{ 'Plantillas de correo instantáneo'|trans({}, 'Modules.Mailsendvx.Admin') }}</h1>
        <p class="mailsendvx-page-subtitle">
          {{ 'Prepara mensajes por evento, previsualiza el contenido renderizado y mantén una sola plantilla activa por evento, idioma y tienda.'|trans({}, 'Modules.Mailsendvx.Admin') }}
        </p>
      </div>
      <div class="mailsendvx-status-cluster">
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Shop'|trans({}, 'Admin.Global') }}</span>
          <strong class="mailsendvx-metric__value">{{ shopName }}</strong>
        </div>
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Templates'|trans({}, 'Modules.Mailsendvx.Admin') }}</span>
          <strong class="mailsendvx-metric__value">{{ templates|length }}</strong>
        </div>
        <div class="mailsendvx-metric">
          <span class="mailsendvx-metric__label">{{ 'Active'|trans({}, 'Admin.Global') }}</span>
          <strong class="mailsendvx-metric__value">{{ activeTemplatesCount }}</strong>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-xl-7">
        {{ form_start(templateForm, {attr: {class: 'mailsendvx-form'}}) }}
        <div class="card mailsendvx-card">
          <h3 class="card-header">
            <i class="material-icons">mail</i>
            {% if currentEditTemplate %}
              {{ 'Editar plantilla'|trans({}, 'Modules.Mailsendvx.Admin') }}: {{ currentEditTemplate.name }}
            {% else %}
              {{ 'Crear plantilla'|trans({}, 'Modules.Mailsendvx.Admin') }}
            {% endif %}
          </h3>
          <div class="card-body">
            <div class="mailsendvx-inline-note">
              {{ 'Si ya existe otra plantilla activa para el mismo evento, idioma y tienda, se desactivará automáticamente.'|trans({}, 'Modules.Mailsendvx.Admin') }}
            </div>
            <div class="form-wrapper">
              {{ form_errors(templateForm) }}
              {{ form_row(templateForm.id_mailsendvx_template) }}

              <div class="row">
                <div class="col-md-6">
                  {{ form_label(templateForm.event_name) }}
                  {{ form_errors(templateForm.event_name) }}
                  {{ form_widget(templateForm.event_name) }}
                  <p class="form-text text-muted mailsendvx-event-code-help">
                    {{ 'Código del evento seleccionado:'|trans({}, 'Modules.Mailsendvx.Admin') }}
                    <code id="mailsendvx-event-code">{{ templateForm.event_name.vars.value ?: '' }}</code>
                  </p>
                </div>
                <div class="col-md-6">
                  {{ form_row(templateForm.template_name) }}
                </div>
              </div>

              <div class="row">
                <div class="col-md-8">
                  {{ form_row(templateForm.subject) }}
                </div>
                <div class="col-md-4">
                  {{ form_row(templateForm.active) }}
                </div>
              </div>

              <div class="row">
                <div class="col-md-6">
                  {{ form_row(templateForm.mail_template) }}
                </div>
                <div class="col-md-3">
                  {{ form_row(templateForm.id_lang) }}
                </div>
                <div class="col-md-3">
                  {{ form_row(templateForm.id_shop) }}
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="card mailsendvx-card mt-3">
          <h3 class="card-header">
            <i class="material-icons">article</i>
            {{ 'Contenido de la plantilla'|trans({}, 'Modules.Mailsendvx.Admin') }}
          </h3>
          <div class="card-body">
            <div class="mailsendvx-inline-note">
              {{ 'La versión en texto plano se genera desde el HTML cada vez que guardas, por lo que el editor HTML es la fuente principal.'|trans({}, 'Modules.Mailsendvx.Admin') }}
            </div>
            <div class="form-wrapper">
              {{ form_row(templateForm.html_content) }}
              {{ form_row(templateForm.text_content) }}
            </div>
          </div>
          <div class="card-footer d-flex justify-content-between align-items-center">
            <a class="btn btn-outline-secondary" href="{{ path('mailsendvx_templates') }}">
              {{ 'Restablecer formulario'|trans({}, 'Modules.Mailsendvx.Admin') }}
            </a>
            <button type="submit" class="btn btn-primary">
              {{ 'Guardar plantilla'|trans({}, 'Modules.Mailsendvx.Admin') }}
            </button>
          </div>
        </div>
        {{ form_rest(templateForm) }}
        {{ form_end(templateForm, {'render_rest': false}) }}
      </div>

      <div class="col-xl-5">
        <div class="card mailsendvx-card mailsendvx-card--aside">
          <h3 class="card-header">
            <i class="material-icons">info</i>
            {{ 'Navegación rápida'|trans({}, 'Modules.Mailsendvx.Admin') }}
          </h3>
          <div class="card-body">
            <ul class="mailsendvx-note-list">
              <li>{{ 'Usa el submenú Wrapper para crear o editar wrappers de correo.'|trans({}, 'Modules.Mailsendvx.Admin') }}</li>
              <li>{{ 'Usa el submenú Documentación para revisar variables, guías de escritura y notas de implementación.'|trans({}, 'Modules.Mailsendvx.Admin') }}</li>
              <li>{{ 'Usa Previsualizar antes de activar plantillas con condiciones o loops de Twig.'|trans({}, 'Modules.Mailsendvx.Admin') }}</li>
            </ul>
          </div>
        </div>

        {% if preview %}
          <div class="card mailsendvx-card mt-3">
            <h3 class="card-header">
              <i class="material-icons">visibility</i>
              {{ 'Previsualización'|trans({}, 'Modules.Mailsendvx.Admin') }}: {{ preview.name }}
            </h3>
            <div class="card-body">
              <div class="mailsendvx-inline-note">
                {{ preview.context_source == 'historical' ? 'Previsualización renderizada con el último payload capturado para este evento.'|trans({}, 'Modules.Mailsendvx.Admin') : 'Previsualización renderizada con datos de ejemplo para este evento.'|trans({}, 'Modules.Mailsendvx.Admin') }}
              </div>
              <div class="mailsendvx-preview-subject">
                <span>{{ 'Subject'|trans({}, 'Admin.Global') }}</span>
                <strong>{{ preview.subject }}</strong>
              </div>
              <div class="mailsendvx-preview-frame">{{ preview.html|raw }}</div>
              <pre class="mailsendvx-text-preview">{{ preview.text }}</pre>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
    <div class="card mailsendvx-card mt-3">
      <h3 class="card-header">
        <i class="material-icons">list</i>
        {{ 'Templates'|trans({}, 'Modules.Mailsendvx.Admin') }}
      </h3>
      <div class="card-body">
        {% if templates %}
          <div class="table-responsive">
            <table class="table mailsendvx-table">
              <thead>
                <tr>
                  <th>{{ 'Name'|trans({}, 'Admin.Global') }}</th>
                  <th>{{ 'Event'|trans({}, 'Modules.Mailsendvx.Admin') }}</th>
                  <th>{{ 'Subject'|trans({}, 'Admin.Global') }}</th>
                  <th>{{ 'Language'|trans({}, 'Admin.Global') }}</th>
                  <th>{{ 'Shop'|trans({}, 'Admin.Global') }}</th>
                  <th>{{ 'Status'|trans({}, 'Admin.Global') }}</th>
                  <th>{{ 'Actions'|trans({}, 'Admin.Actions') }}</th>
                </tr>
              </thead>
              <tbody>
                {% for template in templates %}
                  <tr>
                    <td>
                      <strong>{{ template.name }}</strong>
                      <div class="mailsendvx-table-meta">#{{ template.id_mailsendvx_template }}</div>
                    </td>
                    <td>
                      <span class="mailsendvx-badge mailsendvx-badge--event">{{ template.event_label }}</span>
                      <div class="mailsendvx-table-meta"><code>{{ template.event_name }}</code></div>
                    </td>
                    <td>{{ template.subject }}</td>
                    <td>{{ template.language_label }}</td>
                    <td>{{ template.shop_label }}</td>
                    <td>
                      <span class="mailsendvx-badge {{ template.active ? 'mailsendvx-badge--success' : 'mailsendvx-badge--muted' }}">
                        {{ template.active ? 'Activa'|trans({}, 'Modules.Mailsendvx.Admin') : 'Inactiva'|trans({}, 'Modules.Mailsendvx.Admin') }}
                      </span>
                    </td>
                    <td class="mailsendvx-template-actions">
                      <div class="mailsendvx-action-row">
                        <a class="btn btn-outline-secondary btn-sm" href="{{ path('mailsendvx_templates', {edit: template.id_mailsendvx_template}) }}">{{ 'Editar'|trans({}, 'Modules.Mailsendvx.Admin') }}</a>
                        <a class="btn btn-outline-secondary btn-sm" href="{{ path('mailsendvx_templates', {preview: template.id_mailsendvx_template}) }}">{{ 'Previsualizar'|trans({}, 'Modules.Mailsendvx.Admin') }}</a>
                      </div>
                      <div class="mailsendvx-action-row">
                        <form method="post" action="{{ path('mailsendvx_template_delete', {idTemplate: template.id_mailsendvx_template}) }}" class="mailsendvx-inline-form" onsubmit="return confirm('{{ '¿Eliminar esta plantilla y quitarla de este alcance?'|trans({}, 'Modules.Mailsendvx.Admin')|e('js') }}');">
                          <input type="hidden" name="_token" value="{{ csrf_token('delete-template-' ~ template.id_mailsendvx_template) }}">
                          <button type="submit" class="btn btn-outline-danger btn-sm">{{ 'Eliminar'|trans({}, 'Modules.Mailsendvx.Admin') }}</button>
                        </form>
                        <form method="post" action="{{ path('mailsendvx_template_test', {idTemplate: template.id_mailsendvx_template}) }}" class="mailsendvx-test-form" onsubmit="return confirm('{{ '¿Enviar un correo de prueba usando el contenido renderizado actual?'|trans({}, 'Modules.Mailsendvx.Admin')|e('js') }}');">
                          <input type="hidden" name="_token" value="{{ csrf_token('test-template-' ~ template.id_mailsendvx_template) }}">
                          <input type="email" name="test_email" class="form-control" value="{{ defaultTestEmail }}" placeholder="{{ 'Correo de prueba'|trans({}, 'Modules.Mailsendvx.Admin') }}" required>
                          <button type="submit" class="btn btn-outline-primary btn-sm">{{ 'Enviar prueba'|trans({}, 'Modules.Mailsendvx.Admin') }}</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% else %}
          <div class="mailsendvx-empty-state">
            <h3>{{ 'Aún no hay plantillas.'|trans({}, 'Modules.Mailsendvx.Admin') }}</h3>
            <p>{{ 'Crea la primera plantilla para empezar a probar mensajes disparados por eventos desde esta zona del Back Office.'|trans({}, 'Modules.Mailsendvx.Admin') }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </section>
  <script>
    (function () {
      var eventField = document.getElementById('{{ templateForm.event_name.vars.id }}');
      var eventCode = document.getElementById('mailsendvx-event-code');

      if (!eventField || !eventCode) {
        return;
      }

      var syncEventCode = function () {
        eventCode.textContent = eventField.value || '';
      };

      syncEventCode();
      eventField.addEventListener('change', syncEventCode);
    })();
  </script>
{% endblock %}
